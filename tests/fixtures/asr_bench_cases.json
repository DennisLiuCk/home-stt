      "must_contain": ["好"],
      "must_not_contain": [],
      "note": "最短單音節回應"
    },
    {
      "id": "short_agreement",
      "category": "short_utterance",
      "audio_path": "tests/fixtures/audio/short_agreement.wav",
      "ground_truth": "對啊就是這樣",
      "must_contain": ["對"],
      "must_not_contain": [],
      "note": "短句口語回應"
    },
    {
