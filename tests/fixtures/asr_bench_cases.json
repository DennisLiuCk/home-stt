      "must_contain": ["更慢"],
      "must_not_contain": ["更快"],
      "note": "語義保真 — 「更慢」不可被反轉為「更快」"
    },
    {
      "id": "subject_help_me",
      "category": "semantic",
      "audio_path": "tests/fixtures/audio/subject_help_me.wav",
      "ground_truth": "幫我改一下這段程式碼",
      "must_contain": ["幫我", "程式碼"],
      "must_not_contain": ["幫你"],
      "note": "主詞保留 — 「幫我」不可變成「幫你」"
    }
  ]
}
