      "must_contain": ["pipeline"],
      "must_not_contain": [],
      "note": "問號保留 + 英文術語保留"
    },
    {
      "id": "punct_mixed_comma_question",
      "category": "punctuation",
      "audio_path": "tests/fixtures/audio/punct_mixed_comma_question.wav",
